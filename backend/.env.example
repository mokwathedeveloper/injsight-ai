# ── Database ─────────────────────────────────────────────────────────────────
# PostgreSQL is required. Replace with your actual credentials.
DATABASE_URL=postgresql://injsight:yourpassword@localhost:5432/injsight_db

# ── Auth ──────────────────────────────────────────────────────────────────────
JWT_SECRET=change-me-to-a-long-random-secret

# ── CORS ──────────────────────────────────────────────────────────────────────
CORS_ORIGINS=http://localhost:3000
