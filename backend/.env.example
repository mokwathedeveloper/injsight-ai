# InjSight AI backend configuration

# Database. Default is local SQLite for zero-setup dev.
# For PostgreSQL use e.g.:
# DATABASE_URL=postgresql+psycopg2://injsight:injsight@localhost:5432/injsight
DATABASE_URL=sqlite:///./injsight.db

# JWT
JWT_SECRET=change-me-in-production
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# CORS (comma-separated origins)
CORS_ORIGINS=http://localhost:3000

# Anonymous public analysis rate limit (requests per window)
PUBLIC_ANALYSIS_LIMIT=10
PUBLIC_ANALYSIS_WINDOW_SECONDS=3600
